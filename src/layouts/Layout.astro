---
interface Props {
  title: string;
  description?: string;
  wide?: boolean;
}

const {
  title,
  description = 'kzgrm',
  wide = false
} = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="kzgrm" />
  </head>
  <body>
    <header class="site-header">
      <a class="site-title" href="/">
        <img class="site-icon" src="/favicon.svg" alt="" aria-hidden="true" />
        <img src="/header.png" alt="kzgrm" />
      </a>
      <nav>
        <ul>
          <li><a href="/about">About Us</a></li>
          <li><a href="/activities">Activities</a></li>
          <li><a href="/gallery">Gallery</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </nav>
    </header>
    <main class={`container ${wide ? 'container-wide' : ''}`}>
      <slot />
    </main>
    <footer class="site-footer">
      <small>{new Date().getFullYear()} kazaguruma</small>
    </footer>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --bg: #f8fafc;
    --card: #ffffff;
    --text: #0f172a;
    --muted: #475569;
    --accent: #5A64B1;
    --border: #dbe1ea;
  }

  * {
    box-sizing: border-box;
  }

  img,
  picture,
  video,
  canvas,
  svg {
    max-width: 100%;
    height: auto;
  }

  body {
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.7;
  }

  .site-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--border);
    background: var(--card);
    position: sticky;
    top: 0;
  }

  .site-title {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
  }

  .site-icon {
    width: 28px;
    height: 28px;
    flex: 0 0 auto;
  }

  .site-title img {
    display: block;
    width: auto;
    height: 40px;
  }

  nav ul {
    list-style: none;
    display: flex;
    gap: 1rem;
    margin: 0;
    padding: 0;
  }

  nav a {
    color: var(--muted);
    text-decoration: none;
  }

  nav a:hover {
    color: var(--accent);
  }

  .container {
    width: min(100% - 2rem, 920px);
    margin: 0 auto;
    padding: clamp(1rem, 2vw, 2rem) 0 clamp(2rem, 3vw, 3rem);
  }

  .container-wide {
    width: min(100% - 2rem, 1240px);
  }

  .site-footer {
    text-align: center;
    border-top: 1px solid var(--border);
    padding: 1.25rem;
    color: var(--muted);
  }

  /*
    改行を手動で扱いたいテキスト向け:
    改行文字をそのまま表示しつつ、長い行は折り返す。
  */
  .manual-break {
    white-space: pre-wrap;
    overflow-wrap: anywhere;
  }

  :global(article img) {
    width: min(100%, 720px);
    height: auto;
    display: block;
    margin-inline: auto;
  }

  @media (max-width: 768px) {
    .site-header {
      flex-wrap: wrap;
      padding: 0.75rem 1rem;
    }

    .site-title img {
      height: 32px;
    }

    nav ul {
      flex-wrap: wrap;
      gap: 0.7rem 1rem;
    }

    .container {
      width: min(100% - 1.25rem, 920px);
    }

    .container-wide {
      width: min(100% - 1.25rem, 1240px);
    }
  }
</style>
