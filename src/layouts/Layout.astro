---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'kzgrm'
} = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="kzgrm" />
  </head>
  <body>
    <header class="site-header">
      <a class="site-title" href="/">kzgrm</a>
      <nav>
        <ul>
          <li><a href="/about">about</a></li>
          <li><a href="/activities">activities</a></li>
          <li><a href="/contact">contact</a></li>
        </ul>
      </nav>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer class="site-footer">
      <small>{new Date().getFullYear()} kzgrm</small>
    </footer>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --bg: #f8fafc;
    --card: #ffffff;
    --text: #0f172a;
    --muted: #475569;
    --accent: #2563eb;
    --border: #dbe1ea;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.7;
  }

  .site-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--border);
    background: var(--card);
    position: sticky;
    top: 0;
  }

  .site-title {
    font-weight: 700;
    color: var(--text);
    text-decoration: none;
  }

  nav ul {
    list-style: none;
    display: flex;
    gap: 1rem;
    margin: 0;
    padding: 0;
  }

  nav a {
    color: var(--muted);
    text-decoration: none;
  }

  nav a:hover {
    color: var(--accent);
  }

  .container {
    max-width: 920px;
    margin: 0 auto;
    padding: 2rem 1.25rem 3rem;
  }

  .site-footer {
    text-align: center;
    border-top: 1px solid var(--border);
    padding: 1.25rem;
    color: var(--muted);
  }
</style>
