---
interface Props {
  title: string;
  description?: string;
  wide?: boolean;
}

const {
  title,
  description = 'kzgrm',
  wide = false
} = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- ヘッダー画像を先に取得し、描画までの「一瞬消える」感を抑える -->
    <link rel="preload" href="/header.webp" as="image" type="image/webp" fetchpriority="high" />
    <link rel="preload" href="/favicon.svg" as="image" type="image/svg+xml" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="kzgrm" />
  </head>
  <body>
    <header class="site-header">
      <a class="site-title" href="/">
        <img
          class="site-icon"
          src="/favicon.svg"
          alt=""
          aria-hidden="true"
          width="28"
          height="28"
          fetchpriority="high"
          decoding="sync"
        />
        <img
          class="site-header-logo"
          src="/header.webp"
          alt="kzgrm"
          width="201"
          height="40"
          fetchpriority="high"
          decoding="sync"
        />
      </a>
      <nav>
        <ul>
          <li><a href="/about">About Us</a></li>
          <li><a href="/activities">Activities</a></li>
          <li><a href="/gallery">Gallery</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </nav>
    </header>
    <main class={`container ${wide ? 'container-wide' : ''}`}>
      <slot />
    </main>
    <footer class="site-footer">
      <small>{new Date().getFullYear()} kazaguruma</small>
    </footer>
    <script is:inline>
      (function () {
        var el = document.querySelector('.site-icon');
        if (!el) return;
        var endDeg = Math.floor(Math.random() * 360);
        /* 非ラップ角: 終了より 720deg（2周）大きく開始 → 反時計回りに2回転して終了角へ */
        var startDeg = endDeg + 720;
        el.style.setProperty('--favicon-end', endDeg + 'deg');
        el.style.setProperty('--favicon-start', startDeg + 'deg');
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          el.style.transform = 'rotate(' + endDeg + 'deg)';
        } else {
          el.classList.add('site-icon--spin');
        }
      })();
    </script>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --bg: #f8fafc;
    --card: #ffffff;
    --text: #0f172a;
    --muted: #475569;
    --accent: #5A64B1;
    --border: #dbe1ea;
    /* docs/color-scheme.md と同順 — ヘッダーナビ hover 用 */
    --nav-hover-1: #a66fe4;
    --nav-hover-2: #ffdb53;
    --nav-hover-3: #5a64b1;
    --nav-hover-4: #d2d1d6;
  }

  * {
    box-sizing: border-box;
  }

  /* スクロールバー表示の有無で viewport 幅が変わらないようにする */
  html {
    scrollbar-gutter: stable;
    height: 100%;
  }

  img,
  picture,
  video,
  canvas,
  svg {
    max-width: 100%;
    height: auto;
  }

  body {
    margin: 0;
    min-height: 100%;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.7;
  }

  /* コンテンツが少ないページでもフッターを viewport 下端に置く（スティッキーフッター） */
  body > main {
    flex: 1 1 auto;
    width: 100%;
    min-width: 0;
  }

  .site-header {
    flex-shrink: 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--border);
    background: var(--card);
    position: sticky;
    top: 0;
    /* main が DOM 後ろにあると重なり部分で上に描画されるため、常に前面に */
    z-index: 10;
  }

  .site-title {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
  }

  .site-icon {
    width: 28px;
    height: 28px;
    flex: 0 0 auto;
    display: block;
    transform-origin: center center;
  }

  /* ヘッダー favicon: 乱数の終了角まで、反時計回りに2周（720deg） */
  .site-icon--spin {
    animation: site-icon-spin 1.45s cubic-bezier(0.28, 0.9, 0.32, 1) forwards;
  }

  @keyframes site-icon-spin {
    from {
      transform: rotate(var(--favicon-start));
    }
    to {
      transform: rotate(var(--favicon-end));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-icon--spin {
      animation: none;
      transform: rotate(var(--favicon-end));
    }
  }

  .site-header-logo {
    display: block;
    width: auto;
    height: 40px;
  }

  .site-title img {
    display: block;
  }

  nav ul {
    list-style: none;
    display: flex;
    gap: 1rem;
    margin: 0;
    padding: 0;
  }

  nav a {
    color: var(--muted);
    text-decoration: none;
  }

  nav li:nth-child(1) a:hover {
    color: var(--nav-hover-1);
  }

  nav li:nth-child(2) a:hover {
    color: var(--nav-hover-2);
  }

  nav li:nth-child(3) a:hover {
    color: var(--nav-hover-3);
  }

  nav li:nth-child(4) a:hover {
    color: var(--nav-hover-4);
  }

  .container {
    width: min(100% - 2rem, 920px);
    margin: 0 auto;
    padding: clamp(1rem, 2vw, 2rem) 0 clamp(2rem, 3vw, 3rem);
  }

  .container-wide {
    width: min(100% - 2rem, 1240px);
  }

  /*
    各ページの装飾用リスト（slot 内のため :global）。
    article 内の Markdown 箇条書きは main > article > ul となりこのセレクタに合わない。
  */
  :global(main.container > ul),
  :global(main.container > section > ul) {
    list-style: none;
    margin: 0;
    padding-left: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .site-footer {
    flex-shrink: 0;
    text-align: center;
    padding: 0.65rem 1rem 1rem;
    font-size: 0.75rem;
    color: #94a3b8;
    background: var(--bg);
    border-top: 1px solid rgba(148, 163, 184, 0.25);
  }

  .site-footer small {
    font-weight: 400;
    letter-spacing: 0.02em;
  }

  /*
    改行を手動で扱いたいテキスト向け:
    改行文字をそのまま表示しつつ、長い行は折り返す。
  */
  .manual-break {
    white-space: pre-wrap;
    overflow-wrap: anywhere;
  }

  :global(article img) {
    width: min(100%, 720px);
    height: auto;
    display: block;
    margin-inline: auto;
  }

  @media (max-width: 768px) {
    .site-header {
      flex-wrap: wrap;
      padding: 0.75rem 1rem;
    }

    .site-header-logo {
      height: 32px;
    }

    nav ul {
      flex-wrap: wrap;
      gap: 0.7rem 1rem;
    }

    .container {
      width: min(100% - 1.25rem, 920px);
    }

    .container-wide {
      width: min(100% - 1.25rem, 1240px);
    }
  }
</style>
