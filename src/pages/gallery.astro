---
import Layout from '../layouts/Layout.astro';
import PhotoGalleryViews from '../components/PhotoGalleryViews.svelte';

const baseSamples = [
  { seed: 'kzgrm-g01', alt: 'プレースホルダ 1', caption: 'photo 01' },
  { seed: 'kzgrm-g02', alt: 'プレースホルダ 2', caption: 'photo 02' },
  { seed: 'kzgrm-g03', alt: 'プレースホルダ 3', caption: 'photo 03' },
  { seed: 'kzgrm-g04', alt: 'プレースホルダ 4', caption: 'photo 04' },
  { seed: 'kzgrm-g05', alt: 'プレースホルダ 5', caption: 'photo 05' },
  { seed: 'kzgrm-g06', alt: 'プレースホルダ 6', caption: 'photo 06' },
  { seed: 'kzgrm-g07', alt: 'プレースホルダ 7', caption: 'photo 07' },
  { seed: 'kzgrm-g08', alt: 'プレースホルダ 8', caption: 'photo 08' },
  { seed: 'kzgrm-g09', alt: 'プレースホルダ 9', caption: 'photo 09' },
  { seed: 'kzgrm-g10', alt: 'プレースホルダ 10', caption: 'photo 10' }
] as const;

/** 同じ10枚を循環して20枚分 */
const photos = Array.from({ length: 20 }, (_, i) => {
  const b = baseSamples[i % 10]!;
  const n = i + 1;
  return {
    src: `https://picsum.photos/seed/${b.seed}/640/480`,
    alt: `${b.alt} (${n}/20)`,
    caption: `${b.caption} #${n}`
  };
});
---

<Layout title="kzgrm gallery" description="kzgrm" wide={true}>
  <h1>Gallery</h1>
  <p>写真いっぱいだよ〜〜〜</p>
  <PhotoGalleryViews client:load photos={photos} />
</Layout>
