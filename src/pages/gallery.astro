---
import Layout from '../layouts/Layout.astro';
import PhotoGalleryViews from '../components/PhotoGalleryViews.svelte';

const photos = [
  {
    src: '/header.png',
    alt: 'kzgrm header',
    caption: 'kzgrm'
  },
  {
    src: '/favicon.svg',
    alt: 'kzgrm icon',
    caption: 'kzgrm'
  },
  {
    src: '/header.png',
    alt: 'kzgrm logo',
    caption: 'kzgrm'
  }
];
---

