---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const latestActivities = (await getCollection('activities', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<Layout title="KZGRM Circle | トップ" description="KZGRM Circleの公式サイトです。活動情報を随時更新します。">
  <section>
    <h1>つながりを作る、学びを広げる。</h1>
    <p>
      KZGRM Circleは、メンバー同士がアイデアを持ち寄り、交流しながら成長できるコミュニティです。
    </p>
    <p>
      <a href="/about">サークル紹介を見る</a>
      ・
      <a href="/activities">活動情報を見る</a>
    </p>
  </section>

  <section>
    <h2>直近の活動ハイライト</h2>
    <ul>
      {latestActivities.map((activity) => (
        <li>
          <a href={`/activities/${activity.id}/`}>{activity.data.title}</a>
          {' - '}
          {activity.data.date.toLocaleDateString('ja-JP')}
        </li>
      ))}
    </ul>
  </section>
</Layout>
